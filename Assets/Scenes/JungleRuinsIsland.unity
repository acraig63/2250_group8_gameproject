  m_Script: {fileID: 11500000, guid: 65a9af2cc38f0ea43bbade148816d95d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DefaultNamespace.StoryIntroUI
  introText: "Ye have washed ashore at Jungle Ruins Island...\n\nThree territories
    divide this wretched cove:\nthe open beach where ye first land,\nthe walled pirate
    camp patrolled by the Camp Leader,\nand the dense jungle hiding secrets to the
    north.\n\nDefeat the Camp Leader to claim Key 3 and Map 3.\nBeware the storm
    \u2014 many have been swallowed without trace.\n\nA hidden passage waits at the
    storm's\n northern edge.\nFind it and ye may escape without another fight.\n\nGood
    luck, sailor."
  holdDuration: 30
  fadeDuration: 1.2
  panelColor: {r: 0.05, g: 0.07, b: 0.12, a: 0.92}
  textColor: {r: 0.88, g: 0.8, b: 0.6, a: 1}
  titleColor: {r: 1, g: 0.84, b: 0.15, a: 1}
  promptColor: {r: 0.7, g: 0.65, b: 0.5, a: 1}
  deathColor: {r: 0.9, g: 0.2, b: 0.2, a: 1}
  titleSize: 28
  bodySize: 16
  promptSize: 13
