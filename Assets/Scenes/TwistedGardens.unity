  m_Script: {fileID: 11500000, guid: 65a9af2cc38f0ea43bbade148816d95d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DefaultNamespace.StoryIntroUI
  introText: 'Ye have washed ashore at the Twisted Gardens...


    Many have entered
    the garden walls.

    Few have reached what lies beyond.


    The path winds
    and doubles back, and the cacti show no mercy.

    But press on as a keeper
    waits at the heart of the gardens.


    Answer their question and Key 2 and
    Map 2 are yours.

    Waste time and the gardens will claim you.

    Move swift.
    Think sharp.


    Good luck, sailor. The keeper is NOT known for patience.'
  holdDuration: 30
  fadeDuration: 1.2
  panelColor: {r: 0.05, g: 0.07, b: 0.12, a: 0.92}
  textColor: {r: 0.88, g: 0.8, b: 0.6, a: 1}
  titleColor: {r: 1, g: 0.84, b: 0.15, a: 1}
  promptColor: {r: 0.7, g: 0.65, b: 0.5, a: 1}
  deathColor: {r: 0.9, g: 0.2, b: 0.2, a: 1}
  titleSize: 28
  bodySize: 16
  promptSize: 13
